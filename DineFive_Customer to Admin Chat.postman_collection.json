{
  "info": {
    "_postman_id": "db1239fa-3043-4d80-97d7-f20d040c1854",
    "name": "DineFive - Customer to Admin Chat",
    "description": "Import-ready Postman collection for testing customer to admin chat.\n\nRun order:\n1. Health Check\n2. Customer Login\n3. Admin Login\n4. Customer Start/Open Admin Conversation\n5. Customer Send Text Message\n6. Get Messages\n7. Admin Reply to Customer\n\nCustomer-to-admin message does not require receiverId. Backend auto-resolves the active admin account.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "49361607",
    "_collection_link": "https://go.postman.co/collection/49361607-db1239fa-3043-4d80-97d7-f20d040c1854?source=collection_link"
  },
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Backend is running', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().success).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Confirms the backend is running."
          },
          "response": []
        },
        {
          "name": "Customer Login - Auto Save Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Customer login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "const token = json?.data?.session?.accessToken;",
                  "const userId = json?.data?.user?.id || json?.data?.user?._id;",
                  "if (token) pm.collectionVariables.set('customerToken', token);",
                  "if (userId) pm.collectionVariables.set('customerId', userId);",
                  "pm.test('Role is CUSTOMER', function () {",
                  "  pm.expect(json?.data?.user?.role).to.eql('CUSTOMER');",
                  "});",
                  "pm.test('Customer token saved', function () {",
                  "  pm.expect(token, 'data.session.accessToken').to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Set customerEmail and customerPassword first. Saves customerToken and customerId."
          },
          "response": []
        },
        {
          "name": "Admin Login - Auto Save Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Admin login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "const token = json?.data?.session?.accessToken;",
                  "if (token) pm.collectionVariables.set('adminToken', token);",
                  "pm.test('Role is ADMIN', function () {",
                  "  pm.expect(json?.data?.user?.role).to.eql('ADMIN');",
                  "});",
                  "pm.test('Admin token saved', function () {",
                  "  pm.expect(token, 'data.session.accessToken').to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Set adminEmail and adminPassword first. Saves adminToken."
          },
          "response": []
        }
      ]
    },
    {
      "name": "1. Customer Side",
      "item": [
        {
          "name": "Customer Start/Open Admin Conversation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Conversation opened', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "const conversationId = json?.data?.id || json?.data?._id;",
                  "if (conversationId) pm.collectionVariables.set('adminCustomerConversationId', conversationId);",
                  "pm.test('Conversation id saved', function () {",
                  "  pm.expect(conversationId, 'data.id').to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{customerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/chat/customer/start-admin-conversation",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "chat",
                "customer",
                "start-admin-conversation"
              ]
            },
            "description": "Creates or opens the customer-admin conversation. No body needed."
          },
          "response": []
        },
        {
          "name": "Customer Send Text Message to Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Customer message sent', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "const messageId = json?.data?.messageId;",
                  "if (messageId) pm.collectionVariables.set('lastMessageId', messageId);",
                  "pm.test('Message id returned', function () {",
                  "  pm.expect(messageId, 'data.messageId').to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{customerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hi admin, I need help with my order.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/chat/message/customer-to-admin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "chat",
                "message",
                "customer-to-admin"
              ]
            },
            "description": "Recommended customer-to-admin send request. receiverId is intentionally omitted; backend auto-resolves the active admin."
          },
          "response": []
        },
        {
          "name": "Customer Send Image/Text Message to Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Customer image/text message sent', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 400]);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.messageId) pm.collectionVariables.set('lastMessageId', json.data.messageId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{customerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "text",
                  "value": "Here is my screenshot.",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "value": null
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/chat/message/customer-to-admin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "chat",
                "message",
                "customer-to-admin"
              ]
            },
            "description": "Optional multipart request. Select an image file in Postman. Do not manually set Content-Type."
          },
          "response": []
        },
        {
          "name": "Customer Get Conversations",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Customer conversations returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "const firstId = json?.data?.conversations?.[0]?.id;",
                  "if (!pm.collectionVariables.get('adminCustomerConversationId') && firstId) {",
                  "  pm.collectionVariables.set('adminCustomerConversationId', firstId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{customerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/chat/conversations?limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "chat",
                "conversations"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Customer inbox. The admin conversation should appear here."
          },
          "response": []
        }
      ]

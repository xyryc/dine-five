    {
      "name": "3. Admin Side",
      "item": [
        {
          "name": "Admin Get Customer Conversations",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Admin customer conversations returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "const first = json?.data?.conversations?.[0];",
                  "if (first?.id && !pm.collectionVariables.get('adminCustomerConversationId')) {",
                  "  pm.collectionVariables.set('adminCustomerConversationId', first.id);",
                  "}",
                  "if (first?.customerId && !pm.collectionVariables.get('customerId')) {",
                  "  pm.collectionVariables.set('customerId', first.customerId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
